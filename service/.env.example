# Prisma resolves this path relative to prisma/schema.prisma.
# For VPS deployment this stores SQLite in service/data/prod.db.
DATABASE_URL="file:../data/prod.db"

# Generate on the server:
# openssl rand -base64 48
AUTH_SECRET="replace-with-a-long-random-secret"

# Used only by npm run db:seed on first setup.
SEED_STUDENT_PASSWORD="change-roman-password"
SEED_ADMIN_PASSWORD="change-nikita-password"
