generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonKind {
  CORE
  EXTRA
}

enum LessonBlockType {
  OBJECTIVE
  EXPLANATION
  DEMONSTRATION
  PRACTICE
  PROMPTS
  CHECK
  ARTIFACT
  MARKDOWN
  CALLOUT
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum AssignmentStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SORT_STEPS
  FIND_PROMPT_ERROR
  FILL_BLANK
}

enum AchievementTriggerType {
  LESSON_COMPLETED
  PRACTICE_COMPLETED
  TEST_PASSED
  SCENARIO_SAVED
  MANUAL
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  displayName  String
  role         UserRole @default(STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  lessonProgresses     UserLessonProgress[]
  blockProgresses      UserBlockProgress[]
  assignmentProgresses UserAssignmentProgress[]
  testAttempts         UserTestAttempt[]
  achievements         UserAchievement[]
}

model Lesson {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  subtitle        String?
  description     String?
  kind            LessonKind        @default(CORE)
  status          PublicationStatus @default(DRAFT)
  order           Int
  durationMinutes Int?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  blocks      LessonBlock[]
  assignments Assignment[]
  tests       LessonTest[]
  progresses  UserLessonProgress[]
}

model LessonBlock {
  id          String          @id @default(cuid())
  lessonId    String
  type        LessonBlockType
  title       String
  contentMd   String
  order       Int
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lesson            Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonProgresses  UserLessonProgress[] @relation("LastLessonBlock")
  blockProgresses   UserBlockProgress[]

  @@index([lessonId, order])
}

model Assignment {
  id                String            @id @default(cuid())
  lessonId          String
  title             String
  instructionsMd    String
  expectedProcessMd String?
  checklistMd       String?
  status            PublicationStatus @default(DRAFT)
  order             Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  lesson     Lesson                   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  progresses UserAssignmentProgress[]

  @@index([lessonId, order])
}

model LessonTest {
  id           String            @id @default(cuid())
  lessonId     String
  title        String
  description  String?
  passingScore Int               @default(1)
  status       PublicationStatus @default(DRAFT)
  order        Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  lesson    Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  UserTestAttempt[]

  @@index([lessonId, order])
}

model Question {
  id           String       @id @default(cuid())
  testId       String
  type         QuestionType
  prompt       String
  explanation  String?
  points       Int          @default(1)
  correctText  String?
  correctOrder String?
  order        Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  test    LessonTest       @relation(fields: [testId], references: [id], onDelete: Cascade)
  options QuestionOption[]

  @@index([testId, order])
}

model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean  @default(false)
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, order])
}

model UserLessonProgress {
  id            String         @id @default(cuid())
  userId        String
  lessonId      String
  lastBlockId   String?
  status        ProgressStatus @default(NOT_STARTED)
  percent       Int            @default(0)
  lastVisitedAt DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lastBlock LessonBlock? @relation("LastLessonBlock", fields: [lastBlockId], references: [id], onDelete: SetNull)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model UserBlockProgress {
  id          String    @id @default(cuid())
  userId      String
  blockId     String
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  block LessonBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([userId, blockId])
  @@index([blockId])
}

model UserAssignmentProgress {
  id           String           @id @default(cuid())
  userId       String
  assignmentId String
  status       AssignmentStatus @default(NOT_STARTED)
  submissionMd String?
  submittedAt  DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([userId, assignmentId])
  @@index([assignmentId])
}

model UserTestAttempt {
  id        String   @id @default(cuid())
  userId    String
  testId    String
  score     Int
  maxScore  Int
  isPassed  Boolean  @default(false)
  answers   String?
  createdAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  test LessonTest @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([userId, testId])
  @@index([testId])
}

model Achievement {
  id          String                 @id @default(cuid())
  code        String                 @unique
  title       String
  description String
  icon        String?
  triggerType AchievementTriggerType
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  awardedAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
}

model Scenario {
  id        String            @id @default(cuid())
  slug      String            @unique
  title     String
  summary   String?
  contentMd String
  status    PublicationStatus @default(DRAFT)
  order     Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model GlossaryTerm {
  id         String            @id @default(cuid())
  term       String            @unique
  definition String
  contentMd  String?
  status     PublicationStatus @default(DRAFT)
  order      Int
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model ReferenceItem {
  id        String            @id @default(cuid())
  slug      String            @unique
  title     String
  category  String
  contentMd String
  status    PublicationStatus @default(DRAFT)
  order     Int
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([category, order])
}
