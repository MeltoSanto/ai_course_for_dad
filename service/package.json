{
  "name": "service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:hosting": "npm run build && node scripts/prepare-standalone.mjs",
    "start": "next start -H 0.0.0.0",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "content:import": "node scripts/import-lesson-package.mjs",
    "db:studio": "prisma studio",
    "prod:setup": "prisma migrate deploy && npm run db:seed && npm run build",
    "prod:hosting": "prisma migrate deploy && npm run db:seed && npm run build:hosting"
  },
  "dependencies": {
    "@heroui/react": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "playwright": "^1.61.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
